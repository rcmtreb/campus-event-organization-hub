*.iml
.gradle
/local.properties
local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.DS_Store
/build
/captures
.externalNativeBuild
.cxx

# Firebase — never commit credentials or device-specific config
google-services.json
app/google-services.json

# Windows artefact (reserved device name accidentally created as file)
nul
app/nul

# ADB debug log dumps — temporary debug files, never commit
adb_*.txt

# Local developer build helper — contains machine-specific paths
build_deploy.ps1

# Firebase CLI config — contains project ID but no secrets; safe to commit.
# Uncomment the lines below if you prefer to exclude them too.
# firebase.json
# .firebaserc

# Cloud Function dependencies — regenerated by `npm install`
functions/node_modules/

# Android signing keystores — NEVER commit
*.jks
*.keystore

# Environment / secret files
*.env
.env.*
service-account*.json
*-service-account.json

# Firebase service account key used for FCM HTTP v1 — NEVER commit this
app/src/main/assets/service_account.json

# Java crash logs
hs_err_pid*.log

# Gradle Wrapper JAR
gradle/wrapper/gradle-wrapper.jar

# IntelliJ/Android Studio configuration files
.idea/*.xml
