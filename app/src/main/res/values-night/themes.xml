<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- ── Base Application Theme (Dark Mode) ───────────────────────────── -->
    <style name="Base.Theme.Campuseventorghub" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Brand Colors (Green shades) -->
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorSecondary">@color/primary_orange</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/background_gray</item>
        <item name="android:colorBackground">@color/background_gray</item>

        <!-- Surface -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Components -->
        <item name="materialCardViewStyle">@style/PremiumCard</item>
        <item name="chipStyle">@style/PremiumChip</item>
    </style>

    <style name="Theme.Campuseventorghub" parent="Base.Theme.Campuseventorghub" />

    <!-- ── Premium Card Styles (Dark) ──────────────────────────────────── -->
    <style name="PremiumCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="PremiumCard.Elevated" parent="PremiumCard">
        <item name="cardElevation">@dimen/elevation_high</item>
        <item name="cardBackgroundColor">@color/surface_elevated</item>
    </style>

    <style name="PremiumCard.Event" parent="PremiumCard">
        <item name="cardCornerRadius">@dimen/event_card_corner_radius</item>
        <item name="cardElevation">6dp</item>
        <item name="rippleColor">@color/primary_green_light</item>
    </style>

    <style name="PremiumCard.Stats" parent="PremiumCard">
        <item name="cardCornerRadius">@dimen/radius_full</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/card_border</item>
    </style>

    <!-- ── Premium Chip Styles (Dark) ──────────────────────────────────── -->
    <style name="PremiumChip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipCornerRadius">@dimen/chip_corner_radius</item>
        <item name="chipMinHeight">@dimen/chip_height</item>
        <item name="chipStrokeWidth">1.5dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="chipBackgroundColor">@color/chip_bg_black</item>
        <item name="chipStrokeColor">@color/chip_stroke_black</item>
        <item name="chipStartPadding">12dp</item>
        <item name="chipEndPadding">12dp</item>
    </style>

    <style name="PremiumChip.Badge" parent="Widget.MaterialComponents.Chip.Action">
        <item name="chipCornerRadius">16dp</item>
        <item name="chipMinHeight">28dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipBackgroundColor">@color/primary_green</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="chipStartPadding">10dp</item>
        <item name="chipEndPadding">10dp</item>
    </style>

    <style name="Widget.App.Chip" parent="PremiumChip" />
    <style name="Widget.App.Chip.Detail" parent="PremiumChip">
        <item name="chipBackgroundColor">@color/chip_bg_gray</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

    <style name="DiscoverTabChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipCornerRadius">18dp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipStartPadding">8dp</item>
        <item name="chipEndPadding">8dp</item>
        <item name="android:textSize">13sp</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipBackgroundColor">@color/discover_tab_bg</item>
        <item name="android:textColor">@color/discover_tab_text</item>
    </style>

    <!-- ── Premium Button Styles (Dark - Outline Pattern) ───────────────── -->
    <style name="PremiumButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/radius_full</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textAllCaps">false</item>
        <!-- Dark mode: Green outline + dark fill -->
        <item name="backgroundTint">@color/surface</item>
        <item name="strokeColor">@color/primary_green</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/primary_green</item>
    </style>

    <style name="PremiumButton.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/radius_full</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/primary_green</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/primary_green</item>
    </style>

    <style name="PremiumButton.Ghost" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="cornerRadius">@dimen/radius_full</item>
        <item name="android:minHeight">@dimen/button_height_small</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/primary_green</item>
    </style>

    <!-- ── SearchView Styles (Dark) ─────────────────────────────────── -->
    <style name="Widget.App.SearchView" parent="Widget.AppCompat.SearchView">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="queryBackground">@android:color/transparent</item>
    </style>

    <style name="Widget.App.SearchView.Dark" parent="Widget.AppCompat.SearchView">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="queryBackground">@android:color/transparent</item>
    </style>

    <!-- ── Menu Styles (Dark) ───────────────────────────────────────── -->
    <style name="MenuRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <style name="MenuRowIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
    </style>

    <style name="MenuRowLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="MenuRowChevron">
        <item name="android:layout_width">16dp</item>
        <item name="android:layout_height">16dp</item>
        <item name="android:src">@drawable/ic_chevron_right</item>
        <item name="android:tint">@color/text_hint</item>
    </style>

    <style name="MenuDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/card_border</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
    </style>

    <style name="MenuSectionLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <!-- ── Avatar Style (Dark) ──────────────────────────────────────── -->
    <style name="CircleImageStyle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="PremiumAvatar" parent="CircleImageStyle">
        <item name="cornerSize">50%</item>
    </style>

    <!-- ── FAB Shape Appearance ────────────────────────────────────── -->
    <style name="ShapeAppearance.Premium.FAB" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
