<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Campuseventorghub" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/primaryLightBlue</item>
        <item name="colorPrimaryVariant">@color/primaryDarkBlue</item>
        <item name="colorSecondary">@color/accentOrange</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="materialCardViewStyle">@style/App.CardView</item>
    </style>

    <style name="App.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@android:color/white</item>
        <item name="strokeColor">@android:color/black</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>