<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for Dark Mode -->
    <style name="Base.Theme.Campuseventorghub" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Optimized Dark Colors -->
        <item name="colorPrimary">@color/primaryLightBlue</item>
        <item name="colorPrimaryVariant">@color/primaryDarkBlue</item>
        <item name="colorSecondary">@color/accentOrange</item>
        
        <!-- Surface and Background -->
        <item name="android:windowBackground">#121212</item> <!-- Deep Black/Gray -->
        <item name="android:colorBackground">#121212</item>
        
        <!-- Text Readability -->
        <item name="android:textColorPrimary">#FFFFFF</item> <!-- Pure White for headers -->
        <item name="android:textColorSecondary">#BDBDBD</item> <!-- Light Gray for body -->
        
        <item name="materialCardViewStyle">@style/App.CardView</item>
    </style>

    <style name="App.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">#1E1E1E</item> <!-- Slightly lighter gray for cards -->
        <item name="strokeColor">#333333</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>