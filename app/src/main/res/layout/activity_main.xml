<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray"
    tools:context=".ui.main.MainActivity">

    <!-- ── Top App Bar ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/top_app_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_header"
        android:elevation="0dp"
        android:paddingStart="16dp"
        android:paddingEnd="4dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Page title -->
        <TextView
            android:id="@+id/tv_page_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Discover"
            android:textColor="@color/header_text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"/>

        <!-- Notification bell + badge -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp">

            <ImageView
                android:id="@+id/iv_notif_bell"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_notifications"
                android:tint="@color/header_text"
                android:contentDescription="Notifications"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <!-- Unread badge -->
            <TextView
                android:id="@+id/tv_notif_badge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/badge_notification"
                android:textColor="@color/badge_text"
                android:textSize="9sp"
                android:textStyle="bold"
                android:gravity="center"
                android:visibility="gone"/>

        </FrameLayout>

    </LinearLayout>

    <!-- ── Offline Banner ────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/offline_banner_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/error_red"
        android:gravity="center_vertical"
        android:padding="6dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/top_app_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_offline_banner_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="No internet connection — working offline"
            android:textColor="@color/text_on_primary"
            android:gravity="center"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/btn_close_offline_banner"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/text_on_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Dismiss"
            android:padding="2dp" />
    </LinearLayout>

    <!-- ── Fragment container ───────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/offline_banner_container"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Custom bottom navigation bar (4 tabs) ────────────────────────── -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="@dimen/bottom_nav_height"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:elevation="8dp"
        android:paddingHorizontal="@dimen/space_2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Discover tab -->
        <LinearLayout
            android:id="@+id/tab_discover"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_item_background"
            android:paddingVertical="@dimen/space_2">

            <ImageView
                android:id="@+id/tab_discover_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_discover"
                android:tint="@color/primary_green"
                android:contentDescription="Discover"/>

            <TextView
                android:id="@+id/tab_discover_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Discover"
                android:textSize="11sp"
                android:textColor="@color/primary_green"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Events tab -->
        <LinearLayout
            android:id="@+id/tab_events"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_item_background"
            android:paddingVertical="@dimen/space_2">

            <ImageView
                android:id="@+id/tab_events_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_events"
                android:tint="@color/text_hint"
                android:contentDescription="Events"/>

            <TextView
                android:id="@+id/tab_events_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Events"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Venue tab -->
        <LinearLayout
            android:id="@+id/tab_venue"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_item_background"
            android:paddingVertical="@dimen/space_2">

            <ImageView
                android:id="@+id/tab_venue_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_venue"
                android:tint="@color/text_hint"
                android:contentDescription="Venue"/>

            <TextView
                android:id="@+id/tab_venue_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Venue"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Profile tab -->
        <LinearLayout
            android:id="@+id/tab_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_item_background"
            android:paddingVertical="@dimen/space_2">

            <ImageView
                android:id="@+id/tab_profile_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_person"
                android:tint="@color/text_hint"
                android:contentDescription="Profile"/>

            <TextView
                android:id="@+id/tab_profile_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Profile"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
