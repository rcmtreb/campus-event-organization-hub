<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray"
    android:fitsSystemWindows="false"
    android:orientation="vertical">

    <!-- Subtle Page Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingHorizontal="@dimen/space_4"
        android:paddingVertical="@dimen/space_3">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CREATE EVENT"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_4"
            android:paddingBottom="@dimen/space_4">

            <!-- Banner Preview -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:padding="@dimen/space_4"
                android:layout_marginBottom="@dimen/space_3">

                    <ImageView
                        android:id="@+id/create_event_banner_preview"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_image_placeholder" />

                    <Button
                        android:id="@+id/btn_pick_banner"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_3"
                        android:text="Choose Banner Image"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="@color/primary_green"
                        app:cornerRadius="@dimen/radius_medium"
                        app:strokeColor="@color/primary_green"
                        app:strokeWidth="1dp" />
                </LinearLayout>

            <!-- Event Details -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:padding="@dimen/space_4"
                android:layout_marginBottom="@dimen/space_3">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_3"
                    android:text="EVENT INFORMATION"
                    android:textColor="@color/primary_green"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                    <!-- Title -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_3"
                        android:hint="Event Title *"
                        app:hintTextColor="@color/primary_green"
                        app:boxStrokeColor="@color/primary_green"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_create_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Description -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_3"
                        android:hint="Description *"
                        app:hintTextColor="@color/primary_green"
                        app:boxStrokeColor="@color/primary_green"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_create_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:inputType="textMultiLine"
                            android:lines="3"
                            android:maxLines="6" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Date -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_create_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_3"
                        android:hint="Event Date *"
                        app:hintTextColor="@color/primary_green"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_calendar"
                        app:endIconTint="@color/primary_green"
                        app:boxStrokeColor="@color/primary_green"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_create_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:inputType="none"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:cursorVisible="false" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Start Time -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_create_start_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_3"
                        android:hint="Start Time *"
                        app:hintTextColor="@color/primary_green"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_clock"
                        app:endIconTint="@color/primary_green"
                        app:boxStrokeColor="@color/primary_green"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_create_start_time"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:inputType="none"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:cursorVisible="false" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- End Time -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_create_end_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_3"
                        android:hint="End Time *"
                        app:hintTextColor="@color/primary_green"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_clock"
                        app:endIconTint="@color/primary_green"
                        app:boxStrokeColor="@color/primary_green"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_create_end_time"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:inputType="none"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:cursorVisible="false" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Venue -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_create_venue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_3"
                        android:hint="Venue *"
                        app:hintTextColor="@color/primary_green"
                        app:boxStrokeColor="@color/primary_green"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
                        <AutoCompleteTextView
                            android:id="@+id/acv_create_venue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:inputType="none"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:cursorVisible="false" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Organizer Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_3"
                        android:hint="Organizer Name"
                        app:hintTextColor="@color/primary_green"
                        app:boxStrokeColor="@color/primary_green"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_create_organizer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:inputType="none"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:cursorVisible="false" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Department -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_create_department"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_2"
                        android:hint="Department *"
                        app:hintTextColor="@color/primary_green"
                        app:boxStrokeColor="@color/primary_green"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
                        <AutoCompleteTextView
                            android:id="@+id/acv_create_department"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:inputType="none"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:cursorVisible="false" />
                    </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Target Audience -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:padding="@dimen/space_4"
                android:layout_marginBottom="@dimen/space_3">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_1"
                        android:text="TARGET AUDIENCE *"
                        android:textColor="@color/primary_green"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_3"
                        android:text="Select which departments to notify. Your department is pre-selected."
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_audience"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_dept_campus"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Campus" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_dept_cba"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CBA" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_dept_ccje"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CCJE" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_dept_coed"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COED" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_dept_coe"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COE" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_dept_col"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COL" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_dept_clas"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CLAS" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_dept_gs"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GS" />

                    </com.google.android.material.chip.ChipGroup>

            </LinearLayout>

            <!-- Category -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:padding="@dimen/space_4"
                android:layout_marginBottom="@dimen/space_3">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_3"
                        android:text="CATEGORY *"
                        android:textColor="@color/primary_green"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_cat_academic_professional"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Academic &amp; Professional"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_cat_student_life_social"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student Life &amp; Social" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_cat_athletics_wellness"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Athletics &amp; Wellness" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_cat_arts_culture"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Arts &amp; Culture" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_cat_admin_ceremonial"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Administrative &amp; Ceremonial" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_cat_competitions_interest"
                            style="@style/PremiumChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Competitions &amp; Special Interest" />

                    </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <!-- Submit Button -->
            <Button
                android:id="@+id/btn_create_event_submit"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="@dimen/space_4"
                app:backgroundTint="@color/primary_green"
                android:text="Publish Event"
                android:textAllCaps="false"
                android:textColor="@color/text_on_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="@dimen/radius_full" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
