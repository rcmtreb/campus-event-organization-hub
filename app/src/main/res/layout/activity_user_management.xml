<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <!-- Status bar gradient -->
    <View
        android:id="@+id/status_bar_background"
        android:layout_width="0dp"
        android:layout_height="@dimen/status_bar_height"
        android:background="@drawable/status_bar_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Toolbar + content in a vertical LinearLayout -->
    <LinearLayout
        android:id="@+id/user_mgmt_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/status_bar_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Toolbar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_bar_height"
            android:background="@drawable/bg_header"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="User Roles &amp; Permissions"
                android:textColor="@color/header_text"
                android:textSize="18sp"
                android:textStyle="bold" />
        </FrameLayout>

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp">

        <EditText
            android:id="@+id/et_search_users"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_edit_text_rounded"
            android:drawableStart="@drawable/ic_discover"
            android:drawablePadding="8dp"
            android:hint="Search by name or ID…"
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            app:tint="@color/text_hint" />

    </LinearLayout>

    <!-- Department filter chips — horizontal swipe when labels overflow -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_dept"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="@dimen/space_2">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dept_all"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="All" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dept_cba"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CBA" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dept_ccje"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CCJE" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dept_coed"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COED" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dept_coe"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COE" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dept_col"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COL" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dept_clas"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLAS" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dept_gs"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GS" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- Year Level filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_year"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="@dimen/space_2">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_year_all"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="All Years"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_year_1"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1st Year"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_year_2"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2nd Year"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_year_3"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3rd Year"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_year_4"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4th Year"/>

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- Student Status filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="@dimen/space_2">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_status_all"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="All Status"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_status_active"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_status_inactive"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INACTIVE"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_status_archived"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ARCHIVED"/>

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- Result count -->
    <TextView
        android:id="@+id/tv_user_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        android:text="0 users" />

    <!-- User list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_users"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
