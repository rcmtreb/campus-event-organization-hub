<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_3"
    app:cardElevation="@dimen/card_elevation"
    app:cardCornerRadius="@dimen/event_card_corner_radius"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/surface"
    app:rippleColor="@color/primary_green_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Premium Banner Container with Gradient Overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/event_card_image_height">

            <ImageView
                android:id="@+id/event_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_image_placeholder" />

            <!-- Gradient Overlay for text readability -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_bottom_dark"/>

            <!-- Category Badge - Premium Style -->
            <TextView
                android:id="@+id/event_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/space_3"
                android:layout_gravity="top|start"
                android:background="@drawable/badge_timeline"
                android:paddingHorizontal="@dimen/space_3"
                android:paddingVertical="@dimen/space_1"
                android:textColor="@color/text_on_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <!-- Timeline Badge -->
            <TextView
                android:id="@+id/tv_timeline_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/space_3"
                android:layout_gravity="top|end"
                android:background="@drawable/badge_timeline"
                android:paddingHorizontal="@dimen/space_3"
                android:paddingVertical="@dimen/space_1"
                android:textColor="@color/text_on_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Content section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_4">

            <!-- Title -->
            <TextView
                android:id="@+id/event_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="@dimen/space_2"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.1"/>

            <!-- Description -->
            <TextView
                android:id="@+id/event_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="@dimen/space_3"/>

            <!-- Meta Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_calendar"
                    android:tint="@color/text_hint"/>

                <TextView
                    android:id="@+id/event_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_1"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="@dimen/space_2"
                    android:background="@drawable/dot_divider"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_clock"
                    android:tint="@color/text_hint"/>

                <TextView
                    android:id="@+id/event_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_1"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Status badge (shown only for CANCELLED / POSTPONED) -->
            <TextView
                android:id="@+id/tv_event_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_3"
                android:background="@drawable/badge_timeline"
                android:paddingHorizontal="@dimen/space_3"
                android:paddingVertical="@dimen/space_1"
                android:textColor="@color/text_on_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
