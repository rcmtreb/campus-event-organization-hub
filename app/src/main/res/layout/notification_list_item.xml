<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/notif_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Checkbox — visible only in multi-select mode -->
        <CheckBox
            android:id="@+id/notif_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:visibility="gone"
            android:clickable="false"
            android:focusable="false" />

        <!-- Icon area with red alert dot badge -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp">

            <View
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_login_header"
                android:alpha="0.15" />

            <ImageView
                android:id="@+id/notif_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_notifications"
                app:tint="@color/primary_blue" />

            <!-- Red alert dot — shown when notification is unread -->
            <View
                android:id="@+id/notif_unread_dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="top|end"
                android:background="@color/error_red"
                android:visibility="gone" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notif_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/notif_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <!-- Reason (only shown when non-empty) -->
            <TextView
                android:id="@+id/notif_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Suggested date+time (only shown for POSTPONED) -->
            <TextView
                android:id="@+id/notif_suggested_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/primary_blue"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Respond button — only visible for POSTPONED notifications -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_respond_postpone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Respond"
                android:textSize="12sp"
                app:cornerRadius="20dp"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <!-- Mark as read / unread toggle — hidden in multi-select mode -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mark_read_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Mark as read"
                android:textSize="11sp"
                app:cornerRadius="20dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/primary_blue"
                android:textColor="@color/primary_blue" />

            <TextView
                android:id="@+id/notif_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
