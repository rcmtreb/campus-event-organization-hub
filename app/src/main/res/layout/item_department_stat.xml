<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="@dimen/space_3">

    <!-- Rank Badge -->
    <TextView
        android:id="@+id/tv_dept_rank"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/badge_rank"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/space_3"
        android:orientation="vertical">

        <!-- Department Name -->
        <TextView
            android:id="@+id/tv_dept_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"/>

        <!-- Progress Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="@dimen/space_1"
            android:background="@color/divider"
            android:orientation="horizontal">

            <View
                android:id="@+id/dept_progress_bar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0"
                android:background="@color/primary_green"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Event Count -->
    <TextView
        android:id="@+id/tv_dept_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_3"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"/>

</LinearLayout>
