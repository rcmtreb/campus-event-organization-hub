<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/space_4">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/space_4">

        <ImageView
            android:layout_width="@dimen/icon_medium"
            android:layout_height="@dimen/icon_medium"
            android:src="@drawable/ic_clock"
            app:tint="@color/primary_green"
            android:contentDescription="Attendance" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_2"
            android:text="Attendance Codes"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Event Title -->
    <TextView
        android:id="@+id/tv_dialog_event_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="@dimen/space_4"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Time-In Code Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/space_3">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time-In Code"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/space_2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="@dimen/radius_medium"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/card_border"
                app:cardBackgroundColor="@color/surface_elevated">

                <TextView
                    android:id="@+id/tv_time_in_code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/space_3"
                    android:text="---"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:letterSpacing="0.15" />

            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btn_generate_time_in"
                style="@style/PremiumButton.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height_small"
                android:layout_marginStart="@dimen/space_2"
                android:text="Generate"
                android:textSize="12sp" />

        </LinearLayout>
    </LinearLayout>

    <!-- Time-Out Code Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/space_4">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time-Out Code"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/space_2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="@dimen/radius_medium"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/card_border"
                app:cardBackgroundColor="@color/surface_elevated">

                <TextView
                    android:id="@+id/tv_time_out_code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/space_3"
                    android:text="---"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:letterSpacing="0.15" />

            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btn_generate_time_out"
                style="@style/PremiumButton.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height_small"
                android:layout_marginStart="@dimen/space_2"
                android:text="Generate"
                android:textSize="12sp" />

        </LinearLayout>
    </LinearLayout>

    <!-- Attendance Counter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/space_3"
        android:background="@drawable/bg_attendance_count"
        android:layout_marginBottom="@dimen/space_2">

        <ImageView
            android:layout_width="@dimen/icon_small"
            android:layout_height="@dimen/icon_small"
            android:src="@drawable/ic_check"
            app:tint="@color/success_green"
            android:contentDescription="Attended" />

        <TextView
            android:id="@+id/tv_attendance_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_2"
            android:text="0 students attended"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Event controls for officers -->
    <LinearLayout
        android:id="@+id/layout_event_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/space_2">

        <Button
            android:id="@+id/btn_start_event"
            style="@style/PremiumButton.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start Event"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_end_event"
            style="@style/PremiumButton.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_2"
            android:layout_weight="1"
            android:text="End Event"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
