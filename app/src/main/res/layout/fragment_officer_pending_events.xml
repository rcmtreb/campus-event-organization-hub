<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="false"
    android:background="@color/background_gray">

    <!-- Subtle Page Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingHorizontal="@dimen/space_4"
        android:paddingVertical="@dimen/space_3">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDING EVENTS"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"/>
    </LinearLayout>

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_pending_events"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="@dimen/space_2"
        android:paddingVertical="@dimen/space_2"
        android:clipToPadding="false" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_pending_events_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No pending events awaiting approval."
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
