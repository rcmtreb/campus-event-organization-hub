<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_4">

        <!-- Subtle Page Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/space_4">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MY PROFILE"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="@dimen/space_1"/>
        </LinearLayout>

        <!-- Avatar with Premium Ring -->
        <FrameLayout
            android:id="@+id/profile_avatar_container"
            android:layout_width="@dimen/avatar_large"
            android:layout_height="@dimen/avatar_large"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/space_4">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/avatar_ring"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profile_avatar"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/avatar_placeholder"
                app:shapeAppearanceOverlay="@style/CircleImageStyle"/>

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/badge_edit_button"
                android:src="@drawable/ic_image_placeholder"
                android:padding="6dp"
                app:tint="@color/primary_green"/>
        </FrameLayout>

        <!-- Name & Role -->
        <TextView
            android:id="@+id/profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Full Name"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="@dimen/space_2"/>

        <TextView
            android:id="@+id/profile_role_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/badge_timeline"
            android:paddingHorizontal="@dimen/space_4"
            android:paddingVertical="@dimen/space_1"
            android:text="Student"
            android:textColor="@color/text_on_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="@dimen/space_6"/>

        <!-- Account Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_4"
            style="@style/PremiumCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCOUNT INFO"
                    android:textColor="@color/primary_green"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/space_3"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student ID"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/profile_student_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="@dimen/space_3"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/profile_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="@dimen/space_3"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Department"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/profile_dept"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Academic Info Card (Students only) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_academic_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_4"
            android:visibility="gone"
            style="@style/PremiumCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/space_3">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ACADEMIC INFO"
                        android:textColor="@color/primary_green"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <!-- "Complete Profile" nudge button -->
                    <TextView
                        android:id="@+id/profile_complete_nudge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complete profile"
                        android:textColor="@color/primary_blue"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:visibility="gone"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="@dimen/space_4">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Year Level"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/profile_year_level"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:layout_marginBottom="@dimen/space_3"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Section"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/profile_section"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Course"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/profile_course"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:layout_marginBottom="@dimen/space_3"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/profile_student_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Edit Profile Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_4"
            style="@style/PremiumCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EDIT PROFILE"
                    android:textColor="@color/primary_green"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/space_3"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/profile_gender_layout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_3"
                    android:hint="Gender"
                    app:boxCornerRadiusTopStart="@dimen/radius_medium"
                    app:boxCornerRadiusTopEnd="@dimen/radius_medium"
                    app:boxCornerRadiusBottomStart="@dimen/radius_medium"
                    app:boxCornerRadiusBottomEnd="@dimen/radius_medium"
                    app:boxStrokeColor="@color/primary_green"
                    app:hintTextColor="@color/primary_green">

                    <AutoCompleteTextView
                        android:id="@+id/profile_gender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/profile_mobile_layout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Mobile Number (optional)"
                    app:boxCornerRadiusTopStart="@dimen/radius_medium"
                    app:boxCornerRadiusTopEnd="@dimen/radius_medium"
                    app:boxCornerRadiusBottomStart="@dimen/radius_medium"
                    app:boxCornerRadiusBottomEnd="@dimen/radius_medium"
                    app:boxStrokeColor="@color/primary_green"
                    app:hintTextColor="@color/primary_green">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/profile_mobile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/profile_save_btn"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="Save Changes"
            android:textSize="16sp"
            app:cornerRadius="@dimen/radius_full"
            app:backgroundTint="@color/primary_green"/>

    </LinearLayout>

</ScrollView>
