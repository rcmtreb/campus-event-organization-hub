<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <!-- Status bar gradient -->
    <View
        android:id="@+id/status_bar_background"
        android:layout_width="0dp"
        android:layout_height="@dimen/status_bar_height"
        android:background="@drawable/status_bar_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Toolbar + content -->
    <LinearLayout
        android:id="@+id/attendee_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/status_bar_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Toolbar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_bar_height"
            android:background="@drawable/bg_header"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_toolbar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Attendees"
                android:textColor="@color/header_text"
                android:textSize="20sp"
                android:textStyle="bold" />

        </FrameLayout>

        <!-- Filter bar -->
        <LinearLayout
            android:id="@+id/filter_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:paddingStart="@dimen/space_4"
            android:paddingEnd="@dimen/space_4"
            android:paddingTop="@dimen/space_3"
            android:paddingBottom="@dimen/space_3">

            <!-- Search -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search by name"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:startIconDrawable="@drawable/ic_search"
                app:boxCornerRadiusTopStart="@dimen/radius_medium"
                app:boxCornerRadiusTopEnd="@dimen/radius_medium"
                app:boxCornerRadiusBottomStart="@dimen/radius_medium"
                app:boxCornerRadiusBottomEnd="@dimen/radius_medium">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:imeOptions="actionSearch"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Department + Status spinners -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/space_2">

                <Spinner
                    android:id="@+id/spinner_department"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_small"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_2"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="@dimen/space_3"
                    android:paddingEnd="@dimen/space_3" />

                <Spinner
                    android:id="@+id/spinner_status"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_small"
                    android:layout_weight="1"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="@dimen/space_3"
                    android:paddingEnd="@dimen/space_3" />

            </LinearLayout>

            <!-- Course + Year Level spinners -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/space_2">

                <Spinner
                    android:id="@+id/spinner_course"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_small"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_2"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="@dimen/space_3"
                    android:paddingEnd="@dimen/space_3" />

                <Spinner
                    android:id="@+id/spinner_year_level"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_small"
                    android:layout_weight="1"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="@dimen/space_3"
                    android:paddingEnd="@dimen/space_3" />

            </LinearLayout>

            <!-- Section spinner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/space_2">

                <Spinner
                    android:id="@+id/spinner_section"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_small"
                    android:layout_weight="1"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="@dimen/space_3"
                    android:paddingEnd="@dimen/space_3" />

            </LinearLayout>

        </LinearLayout>

        <!-- Summary chips row -->
        <LinearLayout
            android:id="@+id/summary_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_4"
            android:paddingEnd="@dimen/space_4"
            android:paddingTop="@dimen/space_2"
            android:paddingBottom="@dimen/space_2"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_2"
                style="@style/Widget.MaterialComponents.Chip.Action"
                app:chipBackgroundColor="@color/primary_blue"
                android:textColor="@color/white"
                android:text="Registered: 0" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_timed_in"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_2"
                style="@style/Widget.MaterialComponents.Chip.Action"
                app:chipBackgroundColor="@color/primary_green"
                android:textColor="@color/white"
                android:text="In: 0" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_timed_out"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.Chip.Action"
                app:chipBackgroundColor="@color/text_secondary"
                android:textColor="@color/white"
                android:text="Out: 0" />

        </LinearLayout>

        <!-- Attendee list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_attendees"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/space_4" />

        <!-- Empty state -->
        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="No registered attendees found."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
