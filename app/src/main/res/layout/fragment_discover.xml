<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background_gray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_4">

        <!-- ── Section Header: Departments with Most Events ─────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Departments with Most Events"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="@dimen/space_2" />

        <!-- Time Filter Chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_dept_filter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_3"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="@dimen/space_2">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dept_today"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dept_week"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This Week" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dept_month"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This Month" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dept_year"
                style="@style/PremiumChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This Year" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Departments List -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_4"
            style="@style/PremiumCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_3">

                <LinearLayout
                    android:id="@+id/dept_list_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tv_dept_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="@dimen/space_6"
                    android:text="No events found"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Section Header: Events in Your Department ─────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Events in Your Department"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="@dimen/space_3" />

        <!-- User Department Events List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_my_dept_events"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <TextView
            android:id="@+id/tv_my_dept_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="@dimen/space_6"
            android:text="No events in your department"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
