<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_gray"
    tools:context=".ui.main.MenuFragment">

    <!-- ── Header ─────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_blue"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical">

        <!-- Avatar circle -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/menu_avatar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_person_placeholder"
            app:shapeAppearanceOverlay="@style/CircleImageStyle"
            android:background="@color/primary_dark" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_menu_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UCC Student"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_menu_user_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student \u2022 College of CS"
                android:textColor="#BBDEFB"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Scrollable Content ──────────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── OFFICER TOOLS (hidden for Students) ────────────────────── -->
            <LinearLayout
                android:id="@+id/section_officer_tools"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="OFFICER TOOLS"
                    android:textColor="@color/primary_blue"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/menu_officer_my_events"
                            style="@style/MenuRow">
                            <ImageView style="@style/MenuRowIcon"
                                android:src="@drawable/ic_events"
                                app:tint="@color/primary_blue" />
                            <TextView style="@style/MenuRowLabel"
                                android:text="Manage My Events" />
                            <ImageView style="@style/MenuRowChevron" />
                        </LinearLayout>

                        <View style="@style/MenuDivider" />

                        <LinearLayout
                            android:id="@+id/menu_officer_analytics"
                            style="@style/MenuRow">
                            <ImageView style="@style/MenuRowIcon"
                                android:src="@drawable/ic_analytics"
                                app:tint="@color/primary_blue" />
                            <TextView style="@style/MenuRowLabel"
                                android:text="Event Analytics" />
                            <ImageView style="@style/MenuRowChevron" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── ACCOUNT ─────────────────────────────────────────────────── -->
            <TextView style="@style/MenuSectionLabel" android:text="ACCOUNT" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/menu_profile"
                        style="@style/MenuRow">
                        <ImageView style="@style/MenuRowIcon"
                            android:src="@drawable/ic_person"
                            app:tint="@color/primary_blue" />
                        <TextView style="@style/MenuRowLabel"
                            android:text="My Profile" />
                        <ImageView style="@style/MenuRowChevron" />
                    </LinearLayout>

                    <View style="@style/MenuDivider" />

                    <LinearLayout
                        android:id="@+id/menu_my_events"
                        style="@style/MenuRow">
                        <ImageView style="@style/MenuRowIcon"
                            android:src="@drawable/ic_bookmark"
                            app:tint="@color/primary_blue" />
                        <TextView style="@style/MenuRowLabel"
                            android:text="My Registered Events" />
                        <ImageView style="@style/MenuRowChevron" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── SETTINGS ────────────────────────────────────────────────── -->
            <TextView style="@style/MenuSectionLabel" android:text="SETTINGS" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/menu_notifications_settings"
                        style="@style/MenuRow">
                        <ImageView style="@style/MenuRowIcon"
                            android:src="@drawable/ic_notifications"
                            app:tint="@color/primary_blue" />
                        <TextView style="@style/MenuRowLabel"
                            android:text="Notification Preferences" />
                        <ImageView style="@style/MenuRowChevron" />
                    </LinearLayout>

                    <View style="@style/MenuDivider" />

                    <LinearLayout
                        android:id="@+id/menu_dark_mode"
                        style="@style/MenuRow">
                        <ImageView style="@style/MenuRowIcon"
                            android:src="@drawable/ic_settings"
                            app:tint="@color/primary_blue" />
                        <TextView style="@style/MenuRowLabel"
                            android:text="Appearance &amp; Theme" />
                        <ImageView style="@style/MenuRowChevron" />
                    </LinearLayout>

                    <View style="@style/MenuDivider" />

                    <LinearLayout
                        android:id="@+id/menu_privacy"
                        style="@style/MenuRow">
                        <ImageView style="@style/MenuRowIcon"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/primary_blue" />
                        <TextView style="@style/MenuRowLabel"
                            android:text="Privacy" />
                        <ImageView style="@style/MenuRowChevron" />
                    </LinearLayout>

                    <View style="@style/MenuDivider" />

                    <LinearLayout
                        android:id="@+id/menu_security"
                        style="@style/MenuRow">
                        <ImageView style="@style/MenuRowIcon"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/primary_blue" />
                        <TextView style="@style/MenuRowLabel"
                            android:text="Security" />
                        <ImageView style="@style/MenuRowChevron" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── ABOUT ───────────────────────────────────────────────────── -->
            <TextView style="@style/MenuSectionLabel" android:text="ABOUT" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/menu_help"
                        style="@style/MenuRow">
                        <ImageView style="@style/MenuRowIcon"
                            android:src="@drawable/ic_help"
                            app:tint="@color/primary_blue" />
                        <TextView style="@style/MenuRowLabel"
                            android:text="Help &amp; Support" />
                        <ImageView style="@style/MenuRowChevron" />
                    </LinearLayout>

                    <View style="@style/MenuDivider" />

                    <LinearLayout
                        android:id="@+id/menu_about"
                        style="@style/MenuRow">
                        <ImageView style="@style/MenuRowIcon"
                            android:src="@drawable/ic_info"
                            app:tint="@color/primary_blue" />
                        <TextView style="@style/MenuRowLabel"
                            android:text="About CEOH" />
                        <ImageView style="@style/MenuRowChevron" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── LOG OUT ─────────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/menu_logout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_logout"
                        app:tint="@color/error_red" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="Log Out"
                        android:textColor="@color/error_red"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
