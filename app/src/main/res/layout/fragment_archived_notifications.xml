<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray"
    android:fitsSystemWindows="false"
    android:orientation="vertical">

    <!-- Subtle Page Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/space_4"
        android:paddingHorizontal="@dimen/space_4"
        android:paddingTop="@dimen/space_4">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ARCHIVED NOTIFICATIONS"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"/>
    </LinearLayout>

    <!-- Archive count badge -->
    <TextView
        android:id="@+id/tv_archive_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_4"
        android:layout_marginBottom="@dimen/space_2"
        android:background="@color/primary_orange"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:paddingHorizontal="@dimen/space_3"
        android:paddingVertical="@dimen/space_1"
        android:visibility="gone" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/archive_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_bookmark"
            android:alpha="0.3"
            app:tint="@color/text_hint"
            android:contentDescription="No archived notifications" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="No archived notifications"
            android:textColor="@color/text_hint"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/archive_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        android:visibility="gone" />

</LinearLayout>
