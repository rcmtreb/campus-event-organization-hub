<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="32dp"
    android:background="@color/background_gray">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@android:drawable/ic_dialog_email"
        android:contentDescription="Email verification"
        app:tint="@color/primary_green"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Verify Your Email"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="We've sent a verification link to:"
        android:textAlignment="center"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tv_verification_email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="user@email.com"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@color/primary_green" />

    <TextView
        android:id="@+id/tv_verification_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Click the link in your email to verify your account."
        android:textAlignment="center"
        android:textColor="@color/text_secondary" />

    <Button
        android:id="@+id/btn_open_email_app"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/primary_green"
        android:text="Open Email App"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <Button
        android:id="@+id/btn_resend_verification"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="16dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:text="Resend Verification Email"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Didn't receive the email? Check your spam folder or click resend."
        android:textAlignment="center"
        android:textSize="12sp"
        android:textColor="@color/text_hint" />

</LinearLayout>
