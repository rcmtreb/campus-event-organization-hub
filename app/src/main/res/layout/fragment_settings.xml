<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/background_gray">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_4">

            <!-- Section Header: Appearance -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_2"
                android:text="APPEARANCE"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Theme Selector Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_4"
                style="@style/PremiumCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_4">

                    <!-- Theme Label Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/space_4">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_settings"
                            app:tint="@color/primary_green"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/space_3"
                            android:text="Theme"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Theme Options -->
                    <RadioGroup
                        android:id="@+id/rg_theme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- System Default -->
                        <RadioButton
                            android:id="@+id/rb_theme_system"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Follow System"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:buttonTint="@color/primary_green"
                            android:paddingStart="@dimen/space_2"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"/>

                        <!-- Light Mode -->
                        <RadioButton
                            android:id="@+id/rb_theme_light"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Light Mode"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:buttonTint="@color/primary_green"
                            android:paddingStart="@dimen/space_2"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"/>

                        <!-- Dark Mode -->
                        <RadioButton
                            android:id="@+id/rb_theme_dark"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Dark Mode"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:buttonTint="@color/primary_green"
                            android:paddingStart="@dimen/space_2"/>

                    </RadioGroup>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
