<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_3"
    android:layout_marginVertical="@dimen/space_2"
    app:cardCornerRadius="@dimen/radius_medium"
    app:cardElevation="@dimen/elevation_low">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/space_4"
        android:gravity="center_vertical">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/user_item_avatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_person_placeholder"
            app:shapeAppearanceOverlay="@style/CircleImageStyle" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_4"
            android:orientation="vertical">

            <TextView
                android:id="@+id/user_item_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/user_item_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student ID | Dept"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/user_item_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student"
                android:textStyle="bold"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/bg_button_stretchable"
                android:paddingHorizontal="@dimen/space_2"
                android:paddingVertical="@dimen/space_1"
                android:textSize="12sp"/>

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btn_delete_user"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="@dimen/space_2"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_delete"
                android:contentDescription="Delete user"
                app:tint="@color/error_red" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
