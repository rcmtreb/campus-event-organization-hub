<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <View
        android:id="@+id/status_bar_bg"
        android:layout_width="0dp"
        android:layout_height="@dimen/status_bar_height"
        android:background="@drawable/status_bar_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/status_bar_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_bar_height"
            android:background="@drawable/bg_header_admin"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/header_text"
                android:layout_marginEnd="8dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Academic Year Settings"
                    android:textColor="@color/header_text"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Year-end and student promotions"
                    android:textColor="@color/header_subtitle"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Year-End Date Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="YEAR-END DATE"
                            android:textColor="@color/primary_blue"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Academic year end (MM-dd)"
                            android:textColor="@color/text_hint"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp"/>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. 05-31"
                            app:boxCornerRadiusTopStart="@dimen/radius_small"
                            app:boxCornerRadiusTopEnd="@dimen/radius_small"
                            app:boxCornerRadiusBottomStart="@dimen/radius_small"
                            app:boxCornerRadiusBottomEnd="@dimen/radius_small"
                            app:boxStrokeColor="@color/primary_green"
                            app:hintTextColor="@color/primary_green">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_year_end_date"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:maxLength="5"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inactivity threshold (years before archiving)"
                            android:textColor="@color/text_hint"
                            android:textSize="13sp"
                            android:layout_marginTop="12dp"
                            android:layout_marginBottom="6dp"/>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. 2"
                            app:boxCornerRadiusTopStart="@dimen/radius_small"
                            app:boxCornerRadiusTopEnd="@dimen/radius_small"
                            app:boxCornerRadiusBottomStart="@dimen/radius_small"
                            app:boxCornerRadiusBottomEnd="@dimen/radius_small"
                            app:boxStrokeColor="@color/primary_green"
                            app:hintTextColor="@color/primary_green">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_inactivity_threshold"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLength="2"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_save_settings"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_4"
                            android:text="Save Settings"
                            app:backgroundTint="@color/primary_blue"
                            app:cornerRadius="@dimen/radius_medium"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Promotion Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MANUAL PROMOTION"
                            android:textColor="@color/primary_green"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tv_promotion_info"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginBottom="12dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_promote_now"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Promote Students Now"
                            app:backgroundTint="@color/primary_green"
                            app:cornerRadius="@dimen/radius_medium"/>

                        <TextView
                            android:id="@+id/tv_last_promotion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp"
                            android:layout_marginTop="8dp"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Promotion Log Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RECENT PROMOTIONS"
                            android:textColor="@color/primary_green"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="@dimen/space_2"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_promotion_log"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"/>

                        <TextView
                            android:id="@+id/tv_no_promotions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="No promotions recorded yet."
                            android:textColor="@color/text_hint"
                            android:textSize="13sp"
                            android:paddingVertical="16dp"
                            android:visibility="gone"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View android:layout_width="match_parent" android:layout_height="40dp"/>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
