<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Campuseventorghub" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primaryLightBlue</item>
        <item name="colorPrimaryVariant">@color/primaryDarkBlue</item>
        <item name="colorSecondary">@color/accentOrange</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="materialCardViewStyle">@style/App.CardView</item>
    </style>

    <style name="Theme.Campuseventorghub" parent="Base.Theme.Campuseventorghub" />

    <style name="App.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@android:color/white</item>
        <item name="strokeColor">@android:color/black</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Custom Chip Style -->
    <style name="Widget.App.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@android:color/black</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="chipStrokeColor">@android:color/black</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipIconTint">@android:color/white</item>
    </style>

    <style name="Widget.App.Chip.Detail" parent="Widget.App.Chip">
        <item name="chipBackgroundColor">@android:color/darker_gray</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

    <!-- Custom SearchView Style: Black Background, White Text -->
    <style name="Widget.App.SearchView" parent="Widget.AppCompat.SearchView">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textColorHint">@android:color/white</item>
        <item name="queryBackground">@android:color/transparent</item>
        <item name="searchIcon">@drawable/ic_events</item> <!-- Using an existing drawable for icon -->
        <item name="closeIcon">@drawable/ic_share</item> <!-- Temporary placeholders -->
    </style>
</resources>
