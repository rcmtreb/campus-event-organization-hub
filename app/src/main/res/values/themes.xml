<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. Uses DayNight but forced to Light by default in code -->
    <style name="Base.Theme.Campuseventorghub" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primaryLightBlue</item>
        <item name="colorSecondary">@color/accentOrange</item>
        <item name="android:statusBarColor">@color/primaryDarkBlue</item>
        <item name="android:windowBackground">@color/background_gray</item>
        <item name="materialCardViewStyle">@style/App.CardView</item>

        <!-- Surface colors for BottomNavigationView and other widgets -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorOnSurfaceVariant">#424242</item>

        <!-- Standard text colors -->
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">#424242</item>
    </style>

    <style name="Theme.Campuseventorghub" parent="Base.Theme.Campuseventorghub" />

    <style name="App.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@android:color/white</item>
        <item name="strokeColor">@color/card_stroke_color</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Custom Chip Style -->
    <style name="Widget.App.Chip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_bg_black</item>
        <item name="android:textColor">@color/chip_text_white</item>
        <item name="chipStrokeColor">@color/chip_stroke_black</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipIconTint">@android:color/white</item>
    </style>

    <style name="Widget.App.Chip.Detail" parent="Widget.App.Chip">
        <item name="chipBackgroundColor">@color/chip_bg_gray</item>
        <item name="android:textColor">@color/chip_text_white</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

    <style name="Widget.App.SearchView" parent="Widget.AppCompat.SearchView">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textColorHint">@android:color/white</item>
        <item name="queryBackground">@android:color/transparent</item>
    </style>

    <!-- ── Menu row reusable styles ──────────────────────────────────────── -->
    <style name="MenuRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <style name="MenuRowIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
    </style>

    <style name="MenuRowLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="MenuRowChevron">
        <item name="android:layout_width">16dp</item>
        <item name="android:layout_height">16dp</item>
        <item name="android:src">@drawable/ic_chevron_right</item>
        <item name="android:tint">@color/text_hint</item>
    </style>

    <style name="MenuDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/card_border</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
    </style>

    <style name="MenuSectionLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.12</item>
    </style>

    <!-- Circular image overlay for ShapeableImageView -->
    <style name="CircleImageStyle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
